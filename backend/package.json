{
  "name": "fullstack-3tier-webapp-backend",
  "version": "1.0.0",
  "description": "Full-Stack 3-Tier Web Application Backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
